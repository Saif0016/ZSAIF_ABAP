projection;
strict ( 2 );

define behavior for ZC_TRAVEL_SAIF_M //alias <alias_name>
{
  use create;
  use update;
  use delete;

  use association _booking { create; }
}

define behavior for ZC_BOOKING_SAIF_M //alias <alias_name>
{
  use update;
  use delete;

  use association _travel;
  use association _bookingsuppl { create; }
}

define behavior for ZC_BOOKSUP_SAIF_M //alias <alias_name>
{
  use update;
  use delete;

  use association _Travel;
  use association _booking;
}